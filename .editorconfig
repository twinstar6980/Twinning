[*]
root = true
indent_style = tab
indent_size = 4
tab_width = 4
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true
max_line_length = unset

# Common

[{~,*.md}]
indent_style = tab
indent_size = 4
tab_width = 4

[{~,*.sh,*.cmd}]
indent_style = tab
indent_size = 4
tab_width = 4

[{~,*.json}]
indent_style = tab
indent_size = 4
tab_width = 4

[{~,*.yaml}]
indent_style = space
indent_size = 2
tab_width = 2

[{~,*.xml}]
indent_style = tab
indent_size = 4
tab_width = 4

[{~,*.plist}]
indent_style = tab
indent_size = 4
tab_width = 4

[{~,*.properties}]
indent_style = tab
indent_size = 4
tab_width = 4

[{~,*.hpp,*.cpp,*.cppm}]
indent_style = tab
indent_size = 4
tab_width = 4

[{~,*.ts}]
indent_style = tab
indent_size = 4
tab_width = 4

[{~,*.dart}]
indent_style = space
indent_size = 2
tab_width = 2

[{~,*.kt}]
indent_style = space
indent_size = 2
tab_width = 2

[{~,*.kts}]
indent_style = space
indent_size = 4
tab_width = 4

[{~,*.swift}]
indent_style = space
indent_size = 2
tab_width = 2

[{~,*.cs}]
indent_style = tab
indent_size = 4
tab_width = 4

[{~,*.xaml}]
indent_style = tab
indent_size = 4
tab_width = 4

[{~,*.lua}]
indent_style = tab
indent_size = 4
tab_width = 4

[{~,*.py}]
indent_style = tab
indent_size = 4
tab_width = 4

[{~,*.slnx,*.vcxproj,*.vcxproj.filters,*.csproj,*.csproj.filters,Directory.Packages.props,Directory.Build.props,Directory.Build.target}]
indent_style = space
indent_size = 2
tab_width = 2
end_of_line = crlf

[{~,*.rc,*.def,*.manifest,*.appxmanifest,AppxManifest.xml,NativeMethods.txt,NativeMethods.json,*.pubxml,launchSettings.json}]
indent_style = space
indent_size = 2
tab_width = 2
end_of_line = crlf

# JetBrains

[{~,.editorconfig}]
ij_editorconfig_align_group_field_declarations = false
ij_editorconfig_space_after_colon = false
ij_editorconfig_space_after_comma = true
ij_editorconfig_space_before_colon = false
ij_editorconfig_space_before_comma = false
ij_editorconfig_spaces_around_assignment_operators = true

[{~,*.md}]
ij_markdown_force_one_space_after_blockquote_symbol = true
ij_markdown_force_one_space_after_header_symbol = true
ij_markdown_force_one_space_after_list_bullet = true
ij_markdown_force_one_space_between_words = true
ij_markdown_format_tables = true
ij_markdown_insert_quote_arrows_on_wrap = true
ij_markdown_keep_indents_on_empty_lines = false
ij_markdown_keep_line_breaks_inside_text_blocks = true
ij_markdown_max_lines_around_block_elements = 1
ij_markdown_max_lines_around_header = 1
ij_markdown_max_lines_between_paragraphs = 1
ij_markdown_min_lines_around_block_elements = 1
ij_markdown_min_lines_around_header = 1
ij_markdown_min_lines_between_paragraphs = 1
ij_markdown_wrap_text_if_long = true
ij_markdown_wrap_text_inside_blockquotes = true

[{~,*.properties}]
ij_properties_align_group_field_declarations = false
ij_properties_keep_blank_lines = false
ij_properties_key_value_delimiter = equals
ij_properties_spaces_around_key_value_delimiter = false

[{~,*.json}]
ij_json_array_wrapping = split_into_lines
ij_json_keep_blank_lines_in_code = 0
ij_json_keep_indents_on_empty_lines = false
ij_json_keep_line_breaks = true
ij_json_keep_trailing_comma = true
